    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@sqds/multisig": "^2.1.4",
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
