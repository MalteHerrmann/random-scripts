{
  "name": "solana-authority-audit",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "audit": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devEngines": {
